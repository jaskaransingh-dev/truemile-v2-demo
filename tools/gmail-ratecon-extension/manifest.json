{
  "manifest_version": 3,
  "name": "TrueMile Rate Con",
  "version": "1.0",
  "description": "Send rate confirmation PDFs from Gmail to TrueMile Dispatch Console",
  "permissions": ["activeTab"],
  "host_permissions": [
    "https://mail.google.com/*",
    "http://localhost:3000/*"
  ],
  "content_scripts": [{
    "matches": ["https://mail.google.com/*"],
    "js": ["content.js"],
    "run_at": "document_idle"
  }],
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
